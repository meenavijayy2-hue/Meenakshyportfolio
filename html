/* scroll reveal */
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')});},{threshold:.08});
document.querySelectorAll('.rv').forEach(el=>obs.observe(el));
window.addEventListener('load',()=>{
  document.querySelectorAll('.hero .rv').forEach(el=>el.classList.add('in'));
  charts(); filt('All',document.querySelector('.pill'));
});

/* charts */
function charts(){
