    options:{maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{enabled:false}},scales:{y:{display:false},x:{grid:{display:false},border:{display:false},ticks:{color:'#333',font:{size:10,family:'JetBrains Mono'}}}}}
  });
  new Chart(document.getElementById('effChart'),{
    type:'doughnut',
    data:{datasets:[{data:[60,40],backgroundColor:['#D94F1E','rgba(255,255,255,.04)'],borderWidth:0}]},
    options:{maintainAspectRatio:false,cutout:'86%',plugins:{legend:{display:false},tooltip:{enabled:false}}}
  });
