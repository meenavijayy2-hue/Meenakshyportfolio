<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meenakshy Vijayakumar — Digital Marketing</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=Manrope:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
/* ════════════════════════════════════════
   RESET + TOKENS
════════════════════════════════════════ */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:      #F8F4EE;
  --white:   #FFFCF8;
  --surface: #EFE9DF;
  --border:  rgba(160,135,100,.18);
  --accent:  #D94F1E;
  --accent2: #E8710A;
  --dark:    #17110C;
  --ink:     #2A1E14;
  --stone:   #7A6858;
  --muted:   #B09A87;
  --f-h:'Playfair Display',serif;
  --f-b:'Manrope',sans-serif;
  --f-m:'JetBrains Mono',monospace;
  --ease:cubic-bezier(.22,1,.36,1);
}
html{scroll-behavior:smooth;font-size:16px}
body{background:var(--bg);color:var(--ink);font-family:var(--f-b);overflow-x:hidden;cursor:none}

/* ════════════════════════════════════════
   CURSOR
════════════════════════════════════════ */
#cur{position:fixed;top:0;left:0;pointer-events:none;z-index:9999}
#cur-a{width:7px;height:7px;border-radius:50%;background:var(--accent);position:absolute;transform:translate(-50%,-50%)}
#cur-b{width:30px;height:30px;border-radius:50%;border:1px solid var(--accent);position:absolute;transform:translate(-50%,-50%);opacity:.4;transition:width .4s var(--ease),height .4s var(--ease)}
body:has(a:hover) #cur-b,body:has(button:hover) #cur-b{width:52px;height:52px;opacity:.7}

/* ════════════════════════════════════════
   NAV
════════════════════════════════════════ */
nav{
  position:fixed;top:0;width:100%;z-index:500;
  height:66px;display:flex;align-items:center;justify-content:space-between;
  padding:0 3.5rem;
  background:rgba(248,244,238,.94);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.n-logo{
  display:flex;align-items:center;gap:.55rem;
  font-family:var(--f-b);font-size:.82rem;font-weight:800;
  letter-spacing:-.01em;color:var(--dark);text-decoration:none;
}
.n-dot{width:8px;height:8px;background:var(--accent);border-radius:50%}
.n-links{display:flex;gap:2.4rem}
.n-links a{
  font-family:var(--f-m);font-size:.52rem;letter-spacing:.18em;
  text-transform:uppercase;text-decoration:none;color:var(--stone);
  transition:color .2s;
}
.n-links a:hover{color:var(--accent)}
.n-cta{
  font-family:var(--f-m);font-size:.52rem;letter-spacing:.16em;
  text-transform:uppercase;text-decoration:none;
  padding:.6rem 1.5rem;background:var(--dark);color:var(--bg);
  transition:background .25s;
}
.n-cta:hover{background:var(--accent)}

/* ════════════════════════════════════════
   HERO — FULL RETHINK
   The fix: photo is a BACKGROUND element.
   Text has its own full-width column with
   room to breathe. No collision possible.
════════════════════════════════════════ */
.hero{
  min-height:100vh;
  padding-top:66px;
  display:grid;
  /* 3 columns: gutter | text | photo */
  grid-template-columns:3.5rem 1fr 44%;
  grid-template-rows:1fr auto;
  background:var(--bg);
  position:relative;
}

/* left gutter — vertical label */
.hero-gutter{
  grid-column:1;grid-row:1/3;
  display:flex;align-items:center;justify-content:center;
  padding:2rem 0;border-right:1px solid var(--border);
}
.hero-gutter-txt{
  font-family:var(--f-m);font-size:.46rem;letter-spacing:.28em;
  text-transform:uppercase;color:var(--muted);
  writing-mode:vertical-rl;transform:rotate(180deg);
  white-space:nowrap;
}

/* center text column — has padding on BOTH sides */
.hero-text{
  grid-column:2;grid-row:1;
  padding:5rem 5rem 4rem 3.5rem;  /* right padding creates gap from photo */
  display:flex;flex-direction:column;justify-content:center;
}

/* photo column — full bleed, independent */
.hero-photo-col{
  grid-column:3;grid-row:1/3;
  position:relative;overflow:hidden;
  background:var(--surface);
}
.hero-photo-col img{
  width:100%;height:100%;object-fit:cover;
  object-position:center 15%;
  display:block;
  filter:saturate(.88) contrast(1.03);
  transition:transform 8s ease,filter .8s;
}
.hero-photo-col:hover img{transform:scale(1.03);filter:saturate(.95) contrast(1.05)}

/* small location tag — NOT a heavy bar */
.hero-photo-tag{
  position:absolute;bottom:2rem;left:2rem;right:2rem;
  display:flex;align-items:center;justify-content:space-between;
}
.hp-loc{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(248,244,238,.9);backdrop-filter:blur(8px);
  padding:.5rem .9rem;
}
.hp-loc-dot{width:5px;height:5px;background:var(--accent);border-radius:50%}
.hp-loc-txt{font-family:var(--f-m);font-size:.46rem;letter-spacing:.16em;text-transform:uppercase;color:var(--stone)}
.hp-num{font-family:var(--f-h);font-size:6rem;font-weight:700;font-style:italic;color:rgba(255,255,255,.06);line-height:1}

/* bottom stats row — separate grid row, spans gutter+text */
.hero-stats-row{
  grid-column:1/3;grid-row:2;
  display:flex;border-top:1px solid var(--border);
}
.hsr-item{
  flex:1;padding:1.8rem 0 1.8rem 3.5rem;
  border-right:1px solid var(--border);
}
.hsr-item:last-child{border-right:none}
.hsr-val{
  font-family:var(--f-h);font-size:2rem;font-weight:700;
  letter-spacing:-.04em;color:var(--dark);line-height:1;
}
.hsr-label{
  font-family:var(--f-m);font-size:.46rem;letter-spacing:.16em;
  text-transform:uppercase;color:var(--muted);margin-top:.35rem;
}

/* ── HERO TEXT CONTENT ── */
.h-badge{
  display:inline-flex;align-items:center;gap:.6rem;
  margin-bottom:2.5rem;width:fit-content;
}
.h-pip{
  width:6px;height:6px;background:var(--accent);border-radius:50%;
  animation:pip 2s ease-in-out infinite;
}
@keyframes pip{0%,100%{opacity:1}50%{opacity:.3}}
.h-badge-txt{
  font-family:var(--f-m);font-size:.5rem;letter-spacing:.2em;
  text-transform:uppercase;color:var(--stone);
}

/* NAME — the key: max-width so it never bleeds into photo */
.h-name{
  max-width:520px;   /* hard stop before photo */
  margin-bottom:1.6rem;
}
.h-first{
  display:block;
  font-family:var(--f-h);font-weight:900;font-style:normal;
  font-size:clamp(4rem,7.2vw,8rem);
  line-height:.88;letter-spacing:-.03em;
  color:var(--dark);
}
.h-last{
  display:block;
  font-family:var(--f-h);font-weight:700;font-style:italic;
  font-size:clamp(2.6rem,4.8vw,5.2rem);
  line-height:1.05;letter-spacing:-.02em;
  color:var(--accent);
  margin-top:.3rem;
}

.h-role{
  font-family:var(--f-b);font-size:.7rem;font-weight:500;
  letter-spacing:.2em;text-transform:uppercase;
  color:var(--muted);margin-bottom:2.2rem;
}

.h-bio{
  font-family:var(--f-b);font-size:1rem;font-weight:300;
  line-height:1.82;color:var(--stone);max-width:420px;
  margin-bottom:3rem;
}
.h-bio strong{color:var(--ink);font-weight:600}

.h-actions{display:flex;align-items:center;gap:1.4rem}
.btn-fill{
  display:inline-flex;align-items:center;gap:.8rem;
  background:var(--dark);color:var(--bg);
  padding:1rem 2.2rem;
  font-family:var(--f-m);font-size:.52rem;letter-spacing:.18em;
  text-transform:uppercase;text-decoration:none;
  transition:background .28s var(--ease),gap .28s;cursor:none;
}
.btn-fill:hover{background:var(--accent);gap:1.3rem}
.btn-ghost{
  font-family:var(--f-m);font-size:.5rem;letter-spacing:.15em;
  text-transform:uppercase;color:var(--muted);text-decoration:none;
  padding-bottom:2px;border-bottom:1px solid var(--border);
  transition:color .2s,border-color .2s;
}
.btn-ghost:hover{color:var(--accent);border-color:var(--accent)}

/* ════════════════════════════════════════
   ABOUT BAR — clean, static, professional
════════════════════════════════════════ */
.about-bar{
  background:var(--dark);padding:1.6rem 3.5rem;
  display:flex;align-items:center;gap:2.5rem;
  overflow-x:auto;scrollbar-width:none;
}
.about-bar::-webkit-scrollbar{display:none}
.ab-i{
  font-family:var(--f-b);font-size:.7rem;font-weight:400;
  color:#484848;white-space:nowrap;letter-spacing:.01em;
}
.ab-s{width:3px;height:3px;background:var(--accent);border-radius:50%;opacity:.5;flex-shrink:0}

/* ════════════════════════════════════════
   SHARED SECTION STYLES
════════════════════════════════════════ */
.sec{padding:7rem 3.5rem}
.eyebrow{display:flex;align-items:center;gap:.7rem;margin-bottom:1rem}
.eyebrow-bar{width:22px;height:1.5px;background:var(--accent)}
.eyebrow-txt{
  font-family:var(--f-m);font-size:.5rem;letter-spacing:.22em;
  text-transform:uppercase;color:var(--accent);
}
.sec-title{
  font-family:var(--f-h);font-weight:900;
  font-size:clamp(2.6rem,4.2vw,4.5rem);
  line-height:.92;letter-spacing:-.035em;color:var(--dark);
}
.sec-title em{font-style:italic;font-weight:700;color:var(--stone)}

/* reveal */
.rv{opacity:0;transform:translateY(18px);transition:opacity .8s var(--ease),transform .8s var(--ease)}
.rv.in{opacity:1;transform:none}

/* ════════════════════════════════════════
   WORK
════════════════════════════════════════ */
.work{background:var(--white)}
.work-head{
  display:grid;grid-template-columns:1fr 1fr;
  gap:4rem;align-items:end;margin-bottom:4.5rem;
}
.work-sub{
  font-family:var(--f-b);font-size:.95rem;font-weight:300;
  line-height:1.8;color:var(--stone);
}
.cards{
  display:grid;grid-template-columns:1.35fr 1fr 1fr;
  gap:1px;background:var(--border);
}
.card{
  background:var(--white);padding:3rem 2.6rem;
  display:flex;flex-direction:column;
  position:relative;overflow:hidden;
  transition:background .35s var(--ease);
}
.card-bar{
  position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
  transform:scaleX(0);transform-origin:left;
  transition:transform .45s var(--ease);
}
.card:hover{background:var(--bg)}
.card:hover .card-bar{transform:scaleX(1)}
.card-n{
  font-family:var(--f-h);font-style:italic;font-weight:400;
  font-size:3.5rem;color:rgba(217,79,30,.1);
  line-height:1;margin-bottom:1.6rem;letter-spacing:-.04em;
}
.card-icon{font-size:1.5rem;margin-bottom:1rem}
.card-title{
  font-family:var(--f-b);font-size:.98rem;font-weight:700;
  letter-spacing:-.02em;color:var(--dark);
  margin-bottom:.9rem;line-height:1.25;
}
.card-body{
  font-family:var(--f-b);font-size:.86rem;font-weight:300;
  line-height:1.78;color:var(--stone);flex:1;
}
.card-foot{
  display:flex;justify-content:space-between;
  margin-top:1.8rem;padding-top:1.2rem;
  border-top:1px solid var(--border);
}
.card-tag{font-family:var(--f-m);font-size:.44rem;letter-spacing:.14em;text-transform:uppercase;color:var(--accent)}
.card-loc{font-family:var(--f-m);font-size:.44rem;letter-spacing:.12em;text-transform:uppercase;color:var(--surface)}

/* ════════════════════════════════════════
   IMPACT
════════════════════════════════════════ */
.impact{background:var(--dark);padding:7rem 3.5rem}
.imp-grid{display:grid;grid-template-columns:1fr 1fr;gap:7rem;align-items:center}

.imp-eyebrow .eyebrow-bar{background:#C07030}
.imp-eyebrow .eyebrow-txt{color:#C07030}
.imp-title{
  font-family:var(--f-h);font-weight:900;
  font-size:clamp(2.6rem,4.2vw,4.5rem);
  line-height:.92;letter-spacing:-.035em;color:#F0E8DC;margin-bottom:1.5rem;
}
.imp-title em{font-style:italic;font-weight:700;color:#2a2a2a}
.imp-desc{
  font-family:var(--f-b);font-size:.92rem;font-weight:300;
  line-height:1.82;color:#3a3a3a;margin-bottom:3.5rem;
}
.kpis{
  display:grid;grid-template-columns:1fr 1fr;gap:2rem;
  border-top:1px solid rgba(255,255,255,.05);padding-top:2.5rem;
}
.kl{font-family:var(--f-m);font-size:.44rem;letter-spacing:.18em;text-transform:uppercase;color:#C07030;margin-bottom:.5rem}
.kv{font-family:var(--f-h);font-size:2.8rem;font-weight:900;letter-spacing:-.04em;color:#F0E8DC;line-height:1}
.kn{font-family:var(--f-b);font-size:.78rem;font-weight:300;font-style:italic;color:#3a3a3a;margin-top:.35rem}

.charts{display:flex;flex-direction:column;gap:1px}
.cp{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.04);padding:1.8rem 2.2rem}
.cp-h{display:flex;justify-content:space-between;margin-bottom:1.3rem}
.cp-l{font-family:var(--f-m);font-size:.44rem;letter-spacing:.16em;text-transform:uppercase;color:#2a2a2a}
.cp-c{font-family:var(--f-m);font-size:.41rem;color:#222}
.cw{position:relative;height:145px}
.dc{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;padding-bottom:6px;pointer-events:none}
.dc-v{font-family:var(--f-h);font-size:1.9rem;font-weight:900;color:#F0E8DC}

/* ════════════════════════════════════════
   JOURNEY
════════════════════════════════════════ */
.journey{background:var(--surface);padding:7rem 3.5rem}
.j-grid{display:grid;grid-template-columns:260px 1fr;gap:7rem;margin-top:5rem}
.j-sticky{position:sticky;top:86px}
.j-note{
  font-family:var(--f-b);font-size:.92rem;font-weight:300;
  line-height:1.82;color:var(--stone);margin-top:1.5rem;font-style:italic;
}
.tl{display:flex;flex-direction:column}
.te{padding:2.5rem 0;border-bottom:1px solid var(--border)}
.te:first-child{padding-top:0}
.te:last-child{border-bottom:none}
.te-meta{display:flex;align-items:center;gap:1rem;margin-bottom:1rem}
.te-yr{
  font-family:var(--f-m);font-size:.48rem;letter-spacing:.14em;
  text-transform:uppercase;color:var(--accent);flex-shrink:0;
}
.te-yr.p{color:var(--muted)}
.te-hr{flex:1;height:1px;background:var(--border);position:relative}
.te-hr::before{
  content:'';position:absolute;left:0;top:-3.5px;
  width:8px;height:8px;border-radius:50%;
  background:var(--accent);border:2.5px solid var(--surface);
}
.te-hr.p::before{background:var(--surface);border-color:var(--muted)}
.te-role{
  font-family:var(--f-h);font-weight:700;font-size:1.6rem;
  letter-spacing:-.025em;color:var(--dark);margin-bottom:.2rem;line-height:1.1;
}
.te-co{
  font-family:var(--f-b);font-size:.6rem;font-weight:600;
  letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:.85rem;
}
.te-desc{
  font-family:var(--f-b);font-size:.86rem;font-weight:300;
  line-height:1.78;color:var(--stone);
}

/* ════════════════════════════════════════
   SKILLS
════════════════════════════════════════ */
.skills{background:var(--bg);padding:7rem 3.5rem}
.sk-grid{display:grid;grid-template-columns:220px 1fr;gap:7rem;margin-top:5rem;align-items:start}
.sk-note{
  font-family:var(--f-b);font-size:.88rem;font-weight:300;
  line-height:1.82;color:var(--stone);margin-top:1.5rem;
}
.pills{display:flex;flex-direction:column;gap:.45rem;margin-top:2rem}
.pill{
  font-family:var(--f-m);font-size:.48rem;letter-spacing:.16em;
  text-transform:uppercase;padding:.7rem 1.1rem;
  background:transparent;border:1px solid var(--border);
  color:var(--stone);text-align:left;cursor:none;transition:all .22s;
}
.pill.on,.pill:hover{background:var(--accent);border-color:var(--accent);color:#fff}
.chips{display:flex;flex-wrap:wrap;gap:.65rem}
.chip{
  font-family:var(--f-b);font-size:.86rem;font-weight:400;
  padding:.58rem 1.3rem;border:1px solid var(--border);
  color:var(--ink);background:transparent;
  transition:all .28s var(--ease);animation:chipIn .4s var(--ease) both;
}
.chip:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}
@keyframes chipIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* ════════════════════════════════════════
   FOOTER
════════════════════════════════════════ */
.foot{background:var(--dark);padding:7rem 3.5rem 4.5rem}
.foot-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem}
.foot-h{
  font-family:var(--f-h);font-weight:900;
  font-size:clamp(3rem,5.5vw,6rem);
  line-height:.88;letter-spacing:-.04em;color:#F0E8DC;margin-bottom:2.8rem;
}
.foot-h em{font-style:italic;font-weight:700;color:#222}
.foot-btns{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:3.5rem}
.fb-a{display:inline-flex;align-items:center;gap:.7rem;background:var(--accent);color:#fff;padding:1rem 2rem;font-family:var(--f-m);font-size:.5rem;letter-spacing:.16em;text-transform:uppercase;text-decoration:none;transition:background .25s}
.fb-a:hover{background:#b83d10}
.fb-b{display:inline-flex;align-items:center;gap:.7rem;border:1px solid rgba(255,255,255,.08);color:#3a3a3a;padding:1rem 2rem;font-family:var(--f-m);font-size:.5rem;letter-spacing:.16em;text-transform:uppercase;text-decoration:none;transition:all .25s}
.fb-b:hover{border-color:var(--accent);color:var(--accent)}
.foot-loc-l{font-family:var(--f-m);font-size:.44rem;letter-spacing:.18em;text-transform:uppercase;color:#2a2a2a;margin-bottom:.4rem}
.foot-loc-v{font-family:var(--f-b);font-size:1rem;font-weight:700;color:#F0E8DC}
.fcards{display:flex;flex-direction:column;gap:1px}
.fc{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.04);padding:2.2rem}
.fc-l{font-family:var(--f-m);font-size:.44rem;letter-spacing:.2em;text-transform:uppercase;color:#C07030;margin-bottom:.6rem}
.fc-t{font-family:var(--f-b);font-size:1rem;font-weight:700;color:#F0E8DC;margin-bottom:.2rem}
.fc-s{font-family:var(--f-b);font-size:.8rem;font-weight:300;color:#2a2a2a}
.foot-bot{
  margin-top:5rem;padding-top:2rem;
  border-top:1px solid rgba(255,255,255,.05);
  display:flex;justify-content:space-between;align-items:center;
}
.foot-copy{font-family:var(--f-m);font-size:.44rem;letter-spacing:.16em;text-transform:uppercase;color:#222}
.foot-langs{display:flex;gap:2rem}
.foot-lang{font-family:var(--f-m);font-size:.44rem;letter-spacing:.16em;text-transform:uppercase;color:#222}

/* ════════════════════════════════════════
   RESPONSIVE
════════════════════════════════════════ */
@media(max-width:1000px){
  nav{padding:0 1.5rem}.n-links{display:none}
  .hero{grid-template-columns:0 1fr;grid-template-rows:auto auto auto}
  .hero-gutter{display:none}
  .hero-text{grid-column:1/2;grid-row:1;padding:4rem 1.5rem 3rem}
  .hero-photo-col{grid-column:1/2;grid-row:2;height:65vw;min-height:280px}
  .hero-stats-row{grid-column:1/2;grid-row:3}
  .hsr-item{padding:1.6rem 0 1.6rem 1.5rem}
  .h-name{max-width:100%}
  .sec,.work,.impact,.journey,.skills,.foot{padding:5rem 1.5rem}
  .work-head,.imp-grid,.j-grid,.sk-grid,.foot-grid{grid-template-columns:1fr;gap:3rem}
  .cards{grid-template-columns:1fr}
  .about-bar{padding:1.4rem 1.5rem}
}
</style>
</head>
<body>

<div id="cur"><div id="cur-a"></div><div id="cur-b"></div></div>

<!-- NAV -->
<nav>
  <a class="n-logo" href="#"><span class="n-dot"></span>Meenakshy V.</a>
  <div class="n-links">
    <a href="#work">Work</a>
    <a href="#impact">Impact</a>
    <a href="#journey">Journey</a>
    <a href="#skills">Skills</a>
  </div>
  <a class="n-cta" href="mailto:meenavijayy2@gmail.com">Contact</a>
</nav>

<!-- ══════ HERO ══════ -->
<section class="hero">

