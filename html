let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
(function lp(){rx+=(mx-rx)*.13;ry+=(my-ry)*.13;ca.style.left=mx+'px';ca.style.top=my+'px';cb.style.left=rx+'px';cb.style.top=ry+'px';requestAnimationFrame(lp);})();

